

// expected 1061

func main() s32
{
    x : bool[100] = {?};

    for(@v in x)
    {
        @v = true;
    }

    for(i in 2 < x.len)
    {
        if(x[i])
        {
            for(j : usize = i * 2; j < x.len; j += i)
            {
                x[j] = false;      
            }
        }
    }

    ans : s32 = 0;

    for([is_prime , i] in x)
    {
        if(is_prime)
        {
            ans += cast(s32,i);
        }
    }

    return cast(s32,ans == 1061);
}