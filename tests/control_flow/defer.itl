


#attr(flag)
enum defer_flag : u32
{
    none,
    ret,
    nest,
};

func defer_test(flags: u32, buf: s32[])
{
    x: s32 = 1;
    index: u32 = 0;

    defer { 
        buf[index] = x;
        index += 1;
    }

    if(flags & defer_flag::nest)
    {
        defer {
            buf[index] = x;
            index += 1;
        }

        x += 3;
    }

    // if(flags & defer_flag::ret)
    // {
    //     defer 
    //     { 
    //         buf[index] = 5
    //         index += 1
    //     }
    //     return;
    // }

    defer {
        buf[index] = 2;
        index += 1;
    }

    index += 1;
}

func main() s32
{
    buf: s32[32];

    defer_test(defer_flag::none, buf);

    res1 := buf[0] == 0 && buf[1] == 2 && buf[2] == 1;
    
    std::fill(buf,0);


    defer_test(defer_flag::nest, buf);
    res2 := buf[0] == 4 && buf[1] == 0 && buf[2] == 2 && buf[3] == 4;


    std::println("{}",buf);


    ans := res1 && res2;

    return cast(s32,ans);
}