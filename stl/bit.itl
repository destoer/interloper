namespace std;

constant BITS_IN_BYTE : u32 = 8;

func is_set<$T: Integer>(v: $T, bit: u32) bool
{
    return cast(bool,(v >> bit) & 1);
}


func hamming_weight(set: u64) u32
{
    sum : u32 = 0;

    for(i in 0 < (u64.size * BITS_IN_BYTE))
    {
        sum += cast(u32,is_set(set,cast(u32,i)));
    }

    return sum;
}

func set_bit<T: Integer>(v: $T, bit: u32) $T
{
    return v | (1 << bit);
}

func deset_bit<T: Integer>(v : $T, bit: u32) $T
{
    return v & ~(1 << bit);
}